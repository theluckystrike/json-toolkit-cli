{
    "name": "json-toolkit-cli",
    "version": "0.1.0",
    "description": "All-in-one JSON CLI toolkit — format, validate, diff, query, and convert JSON from the command line. Fast, lightweight, and developer-friendly.",
    "author": "Zovo <hello@zovo.one>",
    "license": "MIT",
    "keywords": [
        "json",
        "formatter",
        "cli",
        "validator",
        "json-diff",
        "jsonpath",
        "json-schema",
        "json-to-csv",
        "json-to-yaml",
        "prettify",
        "command-line",
        "developer-tools"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/theluckystrike/json-toolkit-cli.git"
    },
    "homepage": "https://github.com/theluckystrike/json-toolkit-cli",
    "bugs": {
        "url": "https://github.com/theluckystrike/json-toolkit-cli/issues"
    },
    "bin": {
        "json-toolkit": "./dist/cli.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "prepublishOnly": "npm run build && npm test"
    },
    "dependencies": {
        "ajv": "^8.12.0",
        "commander": "^12.0.0",
        "csv-parse": "^5.5.3",
        "csv-stringify": "^6.4.5",
        "js-yaml": "^4.1.0",
        "jsonpath-plus": "^8.0.0",
        "chalk": "^4.1.2"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.11.0",
        "@typescript-eslint/eslint-plugin": "^6.19.1",
        "@typescript-eslint/parser": "^6.19.1",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "jest": "^29.7.0",
        "prettier": "^3.2.4",
        "ts-jest": "^29.1.2",
        "typescript": "^5.3.3"
    }
}